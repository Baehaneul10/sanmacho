# Supabase Postgres 연결 문자열 (Project Settings → Database → URI)
# 비밀번호에 특수문자가 있으면 URL 인코딩이 필요할 수 있습니다.
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.xxxxx.supabase.co:5432/postgres

# 로컬 Postgres만 쓰고 SSL이 없으면
# DATABASE_SSL=false

# Supabase 원격은 기본적으로 SSL 사용(URL에 supabase.co 포함 시 자동)
# DATABASE_SSL=require

HOST=0.0.0.0
PORT=3000
CORS_ORIGIN=*

TRUST_PROXY_HOPS=1
