# 외부 접속: 0.0.0.0 (기본값). 로컬만이면 127.0.0.1
HOST=0.0.0.0
PORT=3000

# 콤마로 여러 출처 허용. nginx 동일 도메인만 쓰면 * 또는 비우기(아래 기본 true)
# 예: https://yourdomain.com,http://localhost:5173
CORS_ORIGIN=*

# 리버스 프록시 뒤에서 X-Forwarded-* 신뢰 홉 수 (기본 1)
TRUST_PROXY_HOPS=1

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=portfolio
DB_PASSWORD=your_password
DB_NAME=portfolio
